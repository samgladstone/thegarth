---
import Layout from '../layouts/Layout.astro';

const title = 'The Garth Gunnerside — [Placeholder]';
const description = 'A beautiful holiday cottage in Gunnerside, Swaledale. [Placeholder description — to be updated in Phase 2.]';
---

<Layout title={title} description={description}>
  <main class="min-h-screen flex flex-col items-center justify-center bg-base-200">
    <div class="card w-full max-w-lg shadow-xl bg-base-100">
      <div class="card-body items-center text-center gap-4">
        <h1 class="card-title text-3xl font-bold">The Garth</h1>
        <p class="text-base-content/70">
          A holiday cottage in Gunnerside, Swaledale.
        </p>
        <div class="badge badge-neutral">Coming soon</div>
      </div>
    </div>
  </main>
</Layout>
